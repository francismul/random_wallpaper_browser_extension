{
  "name": "random-wallpaper-extension",
  "version": "5.0.0",
  "description": "A browser extension that displays random wallpapers from Unsplash and Pexels",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "build:obfuscated": "node build.js --obfuscate",
    "build:light": "node build.js --obfuscate --obfuscate-level=light",
    "build:medium": "node build.js --obfuscate --obfuscate-level=medium",
    "build:heavy": "node build.js --obfuscate --obfuscate-level=heavy",
    "build:fun": "node build.js --obfuscate --obfuscate-level=fun",
    "watch": "node build.js --watch",
    "clean": "rm -rf dist",
    "test": "node scripts/test-refresh.js",
    "test:options": "node scripts/test-optionsLogic.js",
    "test:messaging": "node scripts/test-messaging.js",
    "test:api": "node scripts/test-api.js",
    "test:check-online": "node scripts/test-checkOnline.js",
    "test:shuffle": "node scripts/test-shuffle.js",
    "test:transitions": "node scripts/test-transitions.js"
  },
  "keywords": [
    "wallpaper",
    "unsplash",
    "pexels",
    "browser-extension"
  ],
  "author": "Francis Mule",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.1.22",
    "esbuild": "^0.25.10",
    "glob": "^11.0.3",
    "javascript-obfuscator": "^4.1.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "lucide": "^0.577.0"
  }
}
